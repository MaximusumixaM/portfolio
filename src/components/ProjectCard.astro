---
import { Image } from "astro:assets";

import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<button
  type="button"
  class="project-card bg-background-default-hover"
  data-project-slug={project.slug}
  aria-haspopup="dialog"
>
  <Image
    class="project-card__image"
    src={project.thumbnail}
    alt=""
    widths={[320, 480, 640]}
    sizes="(max-width: 767px) 30vw, 17vw"
  />
  <span class="project-card__title font-sans text-xl text-foreground-on-accent">
    {project.title}
  </span>
</button>

<style>
  .project-card {
    position: relative;
    aspect-ratio: 1 / 1;
    padding: 0;
    border: none;
    box-shadow: 0 0 7px var(--color-border-strong);
    cursor: pointer;
    overflow: hidden;
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s;
  }

  .project-card:hover .project-card__image {
    opacity: 0.5;
  }

  .project-card__title {
    position: absolute;
    left: -10px;
    top: 0;
    opacity: 0;
    transition: all 0.3s;
    z-index: 2;
  }

  .project-card:hover .project-card__title {
    left: 20px;
    opacity: 1;
  }
</style>
