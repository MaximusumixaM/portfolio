---
import exposeGif from "../assets/images/about/expose.gif";
import { bio, awards, socialLinks } from "../data/site";
---

<div class="about">
  <div class="about__text">
    <h1 class="about__header">Max Nobell-Cluff</h1>
    <h2 class="about__label">Bio</h2>
    <p class="about__body">{bio}</p>
    <h2 class="about__label">Awards</h2>
    {
      awards.map((award) => (
        <p class="about__body">
          {award.date}: {award.title}
          <br />- {award.description}
        </p>
      ))
    }
    <div class="about__social">
      {
        socialLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer">
            <img
              class="about__social-icon"
              src={link.icon.src}
              alt={link.label}
            />
          </a>
        ))
      }
    </div>
  </div>
  <div class="about__photo">
    <img src={exposeGif.src} alt="Photo of Max Nobell-Cluff" />
  </div>
</div>

<style>
  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 2.5rem 1.5rem;
    align-items: start;
  }

  .about__header {
    font-family: "Norms", Helvetica, sans-serif;
    font-size: 1.4rem;
    margin-bottom: 1.5rem;
  }

  .about__label {
    font-family: "Norms", Helvetica, sans-serif;
    font-size: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .about__body {
    font-family: "Norms", Helvetica, sans-serif;
    font-size: 1rem;
    line-height: 1.3;
  }

  .about__social {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .about__social-icon {
    width: 1.75rem;
    height: 1.75rem;
    cursor: pointer;
  }

  .about__photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 767px) {
    .about {
      grid-template-columns: 1fr;
    }
  }
</style>
