---
import { Image } from "astro:assets";
import { projects } from "../data/projects";
---

<dialog class="project-modal bg-background-default text-foreground-default" data-project-modal>
  <button
    type="button"
    class="project-modal__close text-xxl text-foreground-default"
    data-modal-close
    aria-label="Close project details"
  >
    &times;
  </button>
  {
    projects.map((project) => (
      <article class="project-detail" data-project-panel={project.slug} hidden>
        <div class="project-detail__text">
          <h2 class="font-display text-xl">{project.title}</h2>
          <h3 class="font-display text-large">About</h3>
          <p class="font-display text-large">{project.about}</p>
          {project.notes.map((note) => (
            <>
              <h3 class="font-display text-large">{note.label}</h3>
              <p class="font-display text-large">{note.text}</p>
            </>
          ))}
        </div>
        <div class="project-detail__media">
          {project.images.map((image) => (
            <Image
              src={image.src}
              alt={image.alt}
              widths={[480, 768, 1024]}
              sizes="(max-width: 767px) 98vw, 70vw"
            />
          ))}
          {project.videoEmbedUrl && (
            <iframe
              class="project-detail__video"
              src={project.videoEmbedUrl}
              title={`${project.title} video`}
              allowfullscreen
            />
          )}
        </div>
      </article>
    ))
  }
</dialog>

<style>
  .project-modal {
    border: none;
    padding: 0;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
  }

  .project-modal::backdrop {
    background: rgb(0 0 0 / 40%);
  }

  .project-modal__close {
    position: fixed;
    top: 0.5rem;
    right: 1rem;
    z-index: 10;
    line-height: 1;
    background: none;
    border: none;
    cursor: pointer;
  }

  .project-detail[hidden] {
    display: none;
  }

  .project-detail {
    display: grid;
    grid-template-columns: minmax(220px, 22vw) 1fr;
    gap: 2rem;
    height: 100%;
    overflow-y: auto;
    padding: 4rem 2rem 2rem;
  }

  .project-detail__text h2 {
    margin-top: 0;
  }

  .project-detail__text h3,
  .project-detail__text p {
    line-height: 1.3;
  }

  .project-detail__media {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-detail__media :global(img) {
    max-width: 100%;
    display: block;
  }

  .project-detail__video {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
  }

  @media (max-width: 767px) {
    .project-detail {
      grid-template-columns: 1fr;
      padding: 3rem 1rem 2rem;
    }
  }
</style>
